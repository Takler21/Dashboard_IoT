    "PausaTrasLimite": 2
  },
  "Importacion": {
    "MaxArchivoBytes": 1073741824
  },
  "RateLimit": {
    "Honeypot": {
      "PermitidosPorMinuto": 600
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
