{
  "Jwt": {
    "TiempoTokenLogin": 24
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "Gemini": {
    "Url": "https://generativelanguage.googleapis.com/v1beta",
    "Modelo": "gemini-2.5-flash-lite"
  },
  "ClasificadorWorker": {
    "TamanoLote": 50,
    "MaxPendientes": 200,
    "IntervaloMinutos": 5,
